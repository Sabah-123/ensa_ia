# ─── Clé secrète Flask (générer avec : python -c "import secrets; print(secrets.token_hex(32))")
SECRET_KEY=changez_cette_cle_secrete_en_production

# ─── Clé API GROQ (optionnelle — sans elle, mode hors-ligne activé)
# Obtenez votre clé sur : https://console.groq.com 
GROQ_API_KEY=

# ─── Environnement (development / production)
FLASK_ENV=development
FLASK_DEBUG=1
